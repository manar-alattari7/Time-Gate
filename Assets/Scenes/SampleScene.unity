--- !u!114 &486011571
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 486011570}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b87fbd6f6ccf43e448b458268dead45c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuizManager
  questionTextUI: {fileID: 1548887001}
  answerButtons:
  - {fileID: 583695021}
  - {fileID: 910911380}
  - {fileID: 263934654}
  quizPanel: {fileID: 1157351944}
  questions:
  - questionText: "\u0645\u0627 \u0627\u0644\u0623\u0633\u062A\u062E\u062F\u0627\u0645
      \u0627\u0644\u0631\u0626\u064A\u0633\u064A \u0644\u0647\u0630\u0627 \u0627\u0644\u0645\u0633\u0631\u062D\u061F"
    answers:
    - "\u0645\u062E\u0632\u0646 \u0644\u0644\u062D\u0628\u0648\u0628 \u0648\u0627\u0644\u0645\u0624\u0646."
    - "\u0625\u0642\u0627\u0645\u0629 \u0627\u0644\u0639\u0631\u0648\u0636 \u0627\u0644\u0645\u0633\u0631\u062D\u064A\u0629
      \u0648\u0627\u0644\u0627\u062D\u062A\u0641\u0627\u0644\u0627\u062A \u0648\u0627\u0644\u0627\u062C\u062A\u0645\u0627\u0639\u0627\u062A
      \u0627\u0644\u0639\u0627\u0645\u0629."
    - "\u0633\u0627\u062D\u0629 \u0644\u062A\u062F\u0631\u064A\u0628 \u0627\u0644\u062C\u0646\u0648\u062F."
    correctAnswerIndex: 1
  - questionText: "\u0644\u0645\u0627\u0630\u0627 \u0635\u064F\u0645\u0645\u062A
      \u0627\u0644\u0645\u062F\u0631\u062C\u0627\u062A \u0628\u0647\u0630\u0627 \u0627\u0644\u0634\u0643\u0644
      \u0627\u0644\u062F\u0627\u0626\u0631\u064A \u0627\u0644\u0645\u0631\u062A\u0641\u0639\u061F"
    answers:
    - " \u0644\u064A\u062A\u0645\u0643\u0646 \u062C\u0645\u064A\u0639 \u0627\u0644\u062D\u0636\u0648\u0631
      \u0645\u0646 \u0631\u0624\u064A\u0629 \u0648\u0633\u0645\u0627\u0639 \u0627\u0644\u0639\u0631\u0636
      \u0628\u0648\u0636\u0648\u062D."
    - "\u0644\u062A\u062E\u0632\u064A\u0646 \u0627\u0644\u0645\u0639\u062F\u0627\u062A
      \u0627\u0644\u0639\u0633\u0643\u0631\u064A\u0629."
    - "\u0644\u062D\u0645\u0627\u064A\u0629 \u0627\u0644\u0645\u0633\u0631\u062D
      \u0645\u0646 \u0627\u0644\u0623\u0645\u0637\u0627\u0631. "
    correctAnswerIndex: 0
  - questionText: "\u0645\u0627 \u0623\u0647\u0645\u064A\u0629 \u0627\u0644\u0623\u0639\u0645\u062F\u0629
      \u0627\u0644\u0643\u0648\u0631\u0646\u062B\u064A\u0629 \u0641\u064A \u0645\u062F\u064A\u0646\u0629
      \u062C\u0631\u0634\u061F"
    answers:
    - "\u0644\u0644\u0632\u064A\u0646\u0629 \u0641\u0642\u0637"
    - "\u0644\u062F\u0639\u0645 \u0627\u0644\u0645\u0628\u0627\u0646\u064A\u060C
      \u0648\u062A\u0646\u0638\u064A\u0645 \u0627\u0644\u0634\u0648\u0627\u0631\u0639\u060C
      \u0648\u0625\u0638\u0647\u0627\u0631 \u0631\u0648\u0639\u0629 \u0627\u0644\u0639\u0645\u0627\u0631\u0629
      \u0627\u0644\u0631\u0648\u0645\u0627\u0646\u064A\u0629."
    - "\u0644\u0627\u0633\u062A\u062E\u062F\u0627\u0645\u0647\u0627 \u0643\u0633\u062C\u0648\u0646"
    correctAnswerIndex: 1
  - questionText: "\u0628\u0645\u0627\u0630\u0627 \u0643\u0627\u0646 \u064A\u062A\u0645\u064A\u0632
      \u0627\u0644\u0645\u0645\u062B\u0644\u0648\u0646 \u0641\u064A \u0627\u0644\u0645\u0633\u0631\u062D
      \u0627\u0644\u0631\u0648\u0645\u0627\u0646\u064A\u061F"
    answers:
    - "\u0643\u0627\u0646\u0648\u0627 \u064A\u0631\u062A\u062F\u0648\u0646 \u0623\u0642\u0646\u0639\u0629
      \u0645\u0633\u0631\u062D\u064A\u0629 \u0643\u0628\u064A\u0631\u0629 \u0648\u0645\u0639\u0628\u0631\u0629
      \u0644\u0625\u0638\u0647\u0627\u0631 \u0627\u0644\u0634\u062E\u0635\u064A\u0627\u062A
      \u0648\u0625\u064A\u0635\u0627\u0644 \u0627\u0644\u0645\u0634\u0627\u0639\u0631
      \u0644\u0644\u062C\u0645\u0647\u0648\u0631."
    - "\u0643\u0627\u0646\u0648\u0627 \u064A\u0637\u0644\u0642\u0648\u0646 \u0627\u0644\u0633\u0647\u0627\u0645
      \u0627\u0644\u0646\u0627\u0631\u064A\u0629."
    - "\u0643\u0627\u0646\u0648\u0627 \u064A\u0639\u062A\u0645\u062F\u0648\u0646
      \u0639\u0644\u0649 \u0627\u0644\u0625\u0634\u0627\u0631\u0627\u062A \u0641\u0642\u0637."
    correctAnswerIndex: 0
  - questionText: "\u0644\u0645\u0627\u0630\u0627 \u0645\u0627 \u0632\u0627\u0644
      \u0627\u0644\u0645\u0633\u0631\u062D \u0627\u0644\u062C\u0646\u0648\u0628\u064A
      \u0641\u064A \u062C\u0631\u0634 \u0630\u0627 \u0623\u0647\u0645\u064A\u0629
      \u062D\u062A\u0649 \u0627\u0644\u064A\u0648\u0645\u061F"
    answers:
    - "\u0644\u0623\u0646\u0647 \u0645\u062C\u0631\u062F \u0645\u0628\u0646\u0649
      \u062D\u062C\u0631\u064A \u0642\u062F\u064A\u0645."
    - "\u0644\u0623\u0646\u0647 \u064A\u0645\u062B\u0644 \u0625\u0631\u062B\u064B\u0627
      \u062D\u0636\u0627\u0631\u064A\u064B\u0627 \u064A\u0639\u0643\u0633 \u062A\u0627\u0631\u064A\u062E
      \u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0648\u0625\u0646\u062C\u0627\u0632\u0627\u062A\u0647\u0627
      \u0627\u0644\u0645\u0639\u0645\u0627\u0631\u064A\u0629 \u0648\u0627\u0644\u062B\u0642\u0627\u0641\u064A\u0629."
    - "\u0644\u0623\u0646\u0647 \u0623\u064F\u0639\u064A\u062F \u0628\u0646\u0627\u0624\u0647
      \u0628\u0627\u0644\u0643\u0627\u0645\u0644 \u0641\u064A \u0627\u0644\u0639\u0635\u0631
      \u0627\u0644\u062D\u062F\u064A\u062B"
    correctAnswerIndex: 1
